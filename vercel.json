{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://18.116.200.11.nip.io/api/:path*"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}